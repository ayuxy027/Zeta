PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Redis — BullMQ queue for Slack events (queue/slack.queue.ts)
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_BASE_URL=http://localhost:3000
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=replace-with-a-long-random-secret
# AUTH0_ID_TOKEN_SIGNING_ALG=HS256

# Neon Postgres — Google Drive ingest (db/pool.ts)
DB_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Google Drive OAuth — redirect URI must match AUTH0_BASE_URL, e.g.:
# http://localhost:3000/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PDF / OCR (OpenDataLoader — see ocr.txt). Requires Java 11+ on PATH for OpenDataLoader.
# PDF_OCR_STRATEGY=auto|builtin|opendataloader|hybrid
#   auto: fast text layer first; if thin, try OpenDataLoader local, then hybrid if URL set.
# Optional hybrid server for scanned PDFs (pip install "opendataloader-pdf[hybrid]" && opendataloader-pdf-hybrid --port 5002 --force-ocr)
# OPENDATALOADER_HYBRID_URL=http://127.0.0.1:5002
# OPENDATALOADER_HYBRID_MODE=full
# OPENDATALOADER_HYBRID_FALLBACK=0
