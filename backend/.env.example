PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Docker Compose overrides REDIS_URL + PORT + AUTH0_BASE_URL; use DB_URL below for Postgres in compose.
# Auth0 Application URLs: http://localhost:3001/auth/callback
# Google OAuth redirect URIs (add both in Google Cloud Console → Credentials → OAuth client):
#   http://localhost:3001/api/integrations/google/callback
#   http://localhost:3001/api/integrations/google-mail/callback
# Enable APIs: gcloud services enable gmail.googleapis.com drive.googleapis.com --project=YOUR_PROJECT_ID

# Google Workspace OAuth — redirect URI must match:
#   <BACKEND_PUBLIC_URL or AUTH0_BASE_URL>/api/integrations/google-workspace/callback
GOOGLE_WORKSPACE_CLIENT_ID=your-google-workspace-client-id
GOOGLE_WORKSPACE_CLIENT_SECRET=your-google-workspace-client-secret
GOOGLE_WORKSPACE_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/userinfo.profile,https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/documents.readonly,https://www.googleapis.com/auth/drive.readonly,https://www.googleapis.com/auth/drive.file

# Slack OAuth — redirect URI must match:
#   <BACKEND_PUBLIC_URL or AUTH0_BASE_URL>/api/integrations/slack/callback
# For local OAuth flow, prefer localhost to avoid ngrok interstitial pages.
SLACK_REDIRECT_BASE_URL=http://localhost:3001
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_SCOPES=channels:history,groups:history,im:history,mpim:history,channels:read,groups:read,im:read,mpim:read,users:read,team:read

# Redis — BullMQ queue for Slack events (queue/slack.queue.ts)
# Local dev: redis://localhost:6379 | Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_BASE_URL=http://localhost:3001
# Optional public URL for third-party callbacks (ngrok, deployed domain).
# If set, integrations use this instead of AUTH0_BASE_URL for redirect_uri.
BACKEND_PUBLIC_URL=
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=replace-with-a-long-random-secret
# AUTH0_ID_TOKEN_SIGNING_ALG=HS256

# Postgres — Google Drive ingest (db/pool.ts)
# Neon: postgresql://…@…neon.tech/…?sslmode=require
# Docker Compose: postgresql://zeta:zeta@postgres:5432/zeta?sslmode=disable
DB_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Google OAuth (Drive + Gmail) — same client; optional overrides:
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
# GOOGLE_MAIL_REDIRECT_URI=http://localhost:3001/api/integrations/google-mail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google AI — embeddings via gemini-embedding-001 (aistudio.google.com → Get API key)
# Docker Compose: overridden automatically, still required in .env
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Neo4j — decision graph store
# Local dev: bolt://localhost:7687 | Docker Compose: bolt://neo4j:7687 (auto-overridden)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB — vector store for semantic search
# Local dev: http://localhost:8000 | Docker Compose: http://chromadb:8000 (auto-overridden)
CHROMADB_URL=http://localhost:8000

# Groq — LLM for entity extraction + answer synthesis (console.groq.com → API Keys)
GROQ_API_KEY=your-groq-api-key

# Recall.ai — Meeting transcription bot
RECALL_API_KEY=your_recall_api_key
RECALL_BASE_URL=https://us-west-2.recall.ai
RECALL_WEBHOOK_SECRET=use_a_long_random_secret
# How many minutes before start automation should send bot (default: 1)
RECALL_AUTOMATION_JOIN_LEAD_MINUTES=1
