PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Auth0
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_BASE_URL=http://localhost:3000
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=replace-with-a-long-random-secret
# Optional: RS256 (default) or HS256 — must match Auth0 JWT signing algorithm for ID tokens.
# AUTH0_ID_TOKEN_SIGNING_ALG=HS256

# Neon Postgres (Google Drive ingest)
DB_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Google Drive OAuth — redirect URI in Google Cloud must match AUTH0_BASE_URL, e.g.:
# http://localhost:3000/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
