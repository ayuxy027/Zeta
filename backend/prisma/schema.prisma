generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model User {
  id        String   @id @default(cuid())
  auth0Sub  String   @unique
  email     String?
  name      String?
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrationCredentials IntegrationCredential[]
  slackMessages          SlackMessage[]
  gmailMessages          GmailMessage[]
  driveExtractions       DriveExtraction[]
}

model IntegrationCredential {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider        String   // 'google_workspace' | 'slack'

  // OAuth tokens (encrypted at rest)
  accessTokenEnc  String?  // encrypted access token
  refreshTokenEnc String?  // encrypted refresh token
  tokenExpiry     DateTime? // when the access token expires

  // Provider-specific metadata
  providerEmail   String?  // Google: user email, Slack: user email
  providerTeamId  String?  // Slack team ID
  providerTeamName String? // Slack team display name
  providerScopes  String?  // comma-separated scopes granted

  // Connection status
  isActive        Boolean  @default(true)
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integration_credentials")
}

model SlackMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventId     String   @unique
  teamId      String?
  channelId   String
  slackUserId String
  text        String
  ts          String
  threadTs    String?
  rawPayload  Json

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([channelId])
  @@index([teamId])
  @@map("slack_messages")
}

model GmailMessage {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  gmailMessageId String
  threadId       String?
  subject        String?
  from           String?
  to             String?
  date           String?
  snippet        String?
  bodyText       String?
  labelIds       Json     @default("[]")

  createdAt      DateTime @default(now())

  @@unique([userId, gmailMessageId])
  @@index([userId])
  @@map("gmail_messages")
}

model DriveExtraction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName   String
  sourceFileIds Json
  sourcesJson   Json
  extractedText String

  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("drive_extractions")
}
